.DS_Store
__pycache__/
*.py[cod]
*.egg-info/
backend/dist/
.pytest_cache/
.venv/
venv/
.worktrees/

# 大型运行制品和数据库不得进入普通 Git 历史。
*.sqlite
*.sqlite-*
*.db
*.parquet
*.faiss
*.index
*.npy
*.npz

# 仓库只跟踪制品注册表，不跟踪 release 本体或测试工作区。
artifacts/*
!artifacts/releases.yaml
artifacts-test/
backend/.env
bgp_visual_output/
backend/data/published/bge_m3_vector_matrix.npy
backend/data/published/bge_m3_vector_metadata.jsonl
backend/data/published/bge_m3_vector_fast_manifest.json

# BGP 知识库运行制品：由服务器制品库按版本提供，不进入普通 Git 历史。
backend/data/*
!backend/data/README.md
**/sources/raw/objects/
**/source-store/objects/
backend/published/
backend/parsed/
backend/chunks/
backend/cleaned/
backend/markdown/
backend/assets/
backend/entities/
