{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DataField",
  "type": "object",
  "required": ["id", "entity_type", "name", "meaning", "source_refs"],
  "properties": {
    "id": {"type": "string"},
    "entity_type": {"const": "DataField"},
    "name": {"type": "string"},
    "belongs_to": {"type": "array", "items": {"type": "string"}},
    "type": {"type": "string"},
    "meaning": {"type": "string"},
    "used_for": {"type": "array", "items": {"type": "string"}},
    "interpretation_rules": {"type": "array", "items": {"type": "string"}},
    "common_errors": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "review_status": {"enum": ["pending", "approved", "rejected"]}
  }
}
