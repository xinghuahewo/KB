{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/bgpkb/schema/standard_mapping_candidate.schema.json",
  "title": "标准语义映射候选",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "candidate_type",
    "local_value",
    "suggested_mapping",
    "source_refs",
    "confidence",
    "reason",
    "provider",
    "model",
    "prompt_version",
    "status"
  ],
  "properties": {
    "candidate_id": {"type": "string", "minLength": 1},
    "candidate_type": {"enum": ["entity_type", "field", "relation"]},
    "local_value": {"type": "string", "minLength": 1},
    "suggested_mapping": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*:[A-Za-z][A-Za-z0-9_-]*$"},
    "source_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "evidence_summary": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "reason": {"type": "string", "minLength": 1},
    "provider": {"type": "string", "minLength": 1},
    "model": {"type": "string", "minLength": 1},
    "prompt_version": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string"},
    "status": {"const": "pending_review"}
  }
}
