{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RetrievalResult",
  "type": "object",
  "required": [
    "@id",
    "chunk_id",
    "source_ref",
    "review_status",
    "retrieval_method",
    "score"
  ],
  "properties": {
    "schema_version": {"enum": ["retrieval_result_v1", "retrieval_result_v2"]},
    "@id": {"type": "string"},
    "chunk_id": {"type": "string"},
    "doc_id": {"type": "string"},
    "title": {"type": "string"},
    "source_type": {"type": "string"},
    "chunk_type": {"type": "string"},
    "source_ref": {"type": "string"},
    "review_status": {"type": "string"},
    "lifecycle_status": {"type": "string"},
    "retrieval_method": {"type": "string"},
    "score": {"type": "number"},
    "content_preview": {"type": "string"},
    "lexical_score": {"type": ["number", "null"]},
    "lexical_rank": {"type": ["integer", "null"], "minimum": 1},
    "vector_score": {"type": ["number", "null"]},
    "vector_rank": {"type": ["integer", "null"], "minimum": 1},
    "fusion_score": {"type": ["number", "null"]},
    "fusion_rank": {"type": "integer", "minimum": 1},
    "rerank_score": {"type": ["number", "null"]},
    "rerank_rank": {"type": ["integer", "null"], "minimum": 1},
    "match_channels": {
      "type": "array",
      "minItems": 1,
      "items": {"enum": ["lexical", "vector"]},
      "uniqueItems": true
    },
    "section_path": {"type": "array", "items": {"type": "string"}},
    "parent_section_id": {"type": ["string", "null"], "minLength": 1},
    "parent_section_heading": {"type": ["string", "null"]},
    "provider": {"type": ["string", "null"]},
    "model": {"type": ["string", "null"]},
    "degraded": {"type": "boolean"},
    "degraded_reason": {"type": ["string", "null"]}
  },
  "$defs": {
    "requires_v2": {
      "required": ["schema_version"],
      "properties": {
        "schema_version": {"const": "retrieval_result_v2"}
      }
    }
  },
  "dependentSchemas": {
    "lexical_score": {"$ref": "#/$defs/requires_v2"},
    "lexical_rank": {"$ref": "#/$defs/requires_v2"},
    "vector_score": {"$ref": "#/$defs/requires_v2"},
    "vector_rank": {"$ref": "#/$defs/requires_v2"},
    "fusion_score": {"$ref": "#/$defs/requires_v2"},
    "fusion_rank": {"$ref": "#/$defs/requires_v2"},
    "rerank_score": {"$ref": "#/$defs/requires_v2"},
    "rerank_rank": {"$ref": "#/$defs/requires_v2"},
    "match_channels": {"$ref": "#/$defs/requires_v2"},
    "section_path": {"$ref": "#/$defs/requires_v2"},
    "parent_section_id": {"$ref": "#/$defs/requires_v2"},
    "parent_section_heading": {"$ref": "#/$defs/requires_v2"},
    "provider": {"$ref": "#/$defs/requires_v2"},
    "model": {"$ref": "#/$defs/requires_v2"},
    "degraded": {"$ref": "#/$defs/requires_v2"},
    "degraded_reason": {"$ref": "#/$defs/requires_v2"}
  },
  "allOf": [
    {
      "if": {
        "required": ["schema_version"],
        "properties": {"schema_version": {"const": "retrieval_result_v2"}}
      },
      "then": {
        "required": [
          "doc_id",
          "lexical_score",
          "lexical_rank",
          "vector_score",
          "vector_rank",
          "fusion_score",
          "fusion_rank",
          "rerank_score",
          "rerank_rank",
          "match_channels",
          "section_path",
          "parent_section_id",
          "parent_section_heading",
          "provider",
          "model",
          "degraded"
        ],
        "properties": {
          "doc_id": {"type": "string", "minLength": 1},
          "parent_section_id": {"type": "string", "minLength": 1},
          "parent_section_heading": {"type": "string", "minLength": 1}
        }
      }
    },
    {
      "if": {
        "required": ["degraded"],
        "properties": {"degraded": {"const": true}}
      },
      "then": {
        "required": ["provider", "model", "degraded_reason"],
        "properties": {
          "provider": {"type": "string", "minLength": 1},
          "model": {"type": "string", "minLength": 1},
          "degraded_reason": {"type": "string", "minLength": 1}
        }
      }
    }
  ]
}
