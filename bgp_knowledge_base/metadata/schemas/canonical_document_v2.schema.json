{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/bgpkb/schema/canonical-document-v2.json",
  "title": "CanonicalDocumentV2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "doc_id", "source", "runtime", "blocks", "assets"],
  "properties": {
    "schema_version": {"const": "canonical_document_v2"},
    "doc_id": {"type": "string", "minLength": 1},
    "source": {"type": "object"},
    "runtime": {"type": "object"},
    "blocks": {"type": "array", "items": {"type": "object"}},
    "assets": {"type": "array", "items": {"type": "object"}},
    "diagnostics": {"type": "array", "items": {"type": "object"}}
  }
}
