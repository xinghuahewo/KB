{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CleaningV2ReleaseGate",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "passed", "blocking_issues", "details"],
  "properties": {
    "schema_version": {"const": "cleaning_v2_release_gate_v1"},
    "passed": {"type": "boolean"},
    "blocking_issues": {"type": "array", "items": {"type": "string"}},
    "details": {
      "type": "object",
      "required": ["migration_total", "migration_gate_passed", "quarantined_count", "human_acceptance_passed"],
      "properties": {
        "migration_total": {"type": "integer", "minimum": 0},
        "migration_gate_passed": {"type": "integer", "minimum": 0},
        "quarantined_count": {"type": "integer", "minimum": 0},
        "human_acceptance_passed": {"type": "boolean"},
        "heading_hierarchy_f1": {"type": ["number", "null"]},
        "reading_order_accuracy": {"type": ["number", "null"]},
        "table_structure_accuracy": {"type": ["number", "null"]},
        "ocr_character_error_rate": {"type": ["number", "null"]}
      }
    }
  }
}
