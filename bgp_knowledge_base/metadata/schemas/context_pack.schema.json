{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContextPack",
  "type": "object",
  "required": [
    "query",
    "results",
    "citations",
    "excluded_by_policy"
  ],
  "properties": {
    "schema_version": {"enum": ["context_pack_v1", "context_pack_v2"]},
    "query": {"type": "string"},
    "normalized_query": {"type": "string"},
    "results": {
      "type": "array",
      "items": {"$ref": "retrieval_result.schema.json"}
    },
    "citations": {"type": "array", "items": {"type": "object"}},
    "excluded_by_policy": {"type": "array", "items": {"type": "object"}},
    "generated_by": {"type": "string"},
    "requested_query_type": {"enum": ["fact", "procedure", "policy", "global", "auto"]},
    "resolved_query_type": {"enum": ["fact", "procedure", "policy", "global"]},
    "token_budget": {"type": "integer", "minimum": 1, "maximum": 8000},
    "context_units": {
      "type": "array",
      "items": {"$ref": "context_unit.schema.json"}
    },
    "provider": {"type": ["string", "null"]},
    "model": {"type": ["string", "null"]},
    "degraded": {"type": "boolean"},
    "degraded_reason": {"type": ["string", "null"]},
    "trim_events": {"type": "array", "items": {"type": "object"}}
  },
  "allOf": [
    {
      "if": {
        "required": ["degraded"],
        "properties": {"degraded": {"const": true}}
      },
      "then": {
        "required": ["provider", "model", "degraded_reason"],
        "properties": {
          "provider": {"type": "string", "minLength": 1},
          "model": {"type": "string", "minLength": 1},
          "degraded_reason": {"type": "string", "minLength": 1}
        }
      }
    }
  ]
}
