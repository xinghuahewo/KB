{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContextUnit",
  "type": "object",
  "required": [
    "schema_version",
    "context_id",
    "mode",
    "doc_id",
    "section_path",
    "parent_section_id",
    "parent_section_heading",
    "included_chunk_ids",
    "included_block_ids",
    "content",
    "estimated_tokens",
    "actual_tokens",
    "max_rerank_score",
    "trim_events",
    "citations"
  ],
  "properties": {
    "schema_version": {"const": "context_unit_v1"},
    "context_id": {"type": "string", "minLength": 1},
    "mode": {
      "enum": ["matched_chunk", "parent_span", "full_section", "summary"]
    },
    "doc_id": {"type": "string", "minLength": 1},
    "section_path": {
      "type": "array",
      "items": {"type": "string"}
    },
    "parent_section_id": {"type": "string", "minLength": 1},
    "parent_section_heading": {"type": "string"},
    "included_chunk_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "included_block_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "content": {"type": "string"},
    "estimated_tokens": {"type": "integer", "minimum": 0},
    "actual_tokens": {"type": ["integer", "null"], "minimum": 0},
    "max_rerank_score": {"type": "number"},
    "trim_events": {"type": "array", "items": {"type": "object"}},
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chunk_id", "source_ref"],
        "properties": {
          "chunk_id": {"type": "string", "minLength": 1},
          "source_ref": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
