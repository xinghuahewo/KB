# DeepSeek 兼容 Chat API。不要把真实密钥提交到仓库。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=30

# SiliconFlow BGE-M3。真实密钥只放环境变量，不提交到仓库。
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1/embeddings
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_TIMEOUT_SECONDS=30

# 阿里云 PAI/EAS BGE-M3 兼容入口，按需启用。
ALIYUN_BGE_M3_ENDPOINT=
ALIYUN_BGE_M3_API_KEY=
ALIYUN_BGE_M3_MODEL=BAAI/bge-m3
ALIYUN_BGE_M3_TIMEOUT_SECONDS=30

# 当前阶段保留本地模型禁用边界。
LOCAL_MODEL_ENABLED=false

# 独立可写的会话历史库；不得指向发布知识库文件。
BGP_CHAT_DB_PATH=runtime/chat/chat_history.sqlite3
# 生产部署应使用稳定的随机盐；匿名客户端标识仅用于命名空间隔离，不是认证。
BGP_CHAT_CLIENT_SALT=
