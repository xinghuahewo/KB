{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DataSource",
  "type": "object",
  "required": ["id", "entity_type", "name", "description", "suitable_for", "limitations", "source_refs"],
  "properties": {
    "id": {"type": "string"},
    "entity_type": {"const": "DataSource"},
    "name": {"type": "string"},
    "category": {"type": "string"},
    "description": {"type": "string"},
    "data_objects": {"type": "array", "items": {"type": "string"}},
    "time_granularity": {"type": "object"},
    "suitable_for": {"type": "array", "items": {"type": "string"}},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "related_tools": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "review_status": {"enum": ["pending", "approved", "rejected"]}
  }
}

