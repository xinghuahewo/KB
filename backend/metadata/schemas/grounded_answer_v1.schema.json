{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/bgpkb/schema/grounded-answer-v1.json",
  "title": "GroundedAnswerV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "answer",
    "claims",
    "evidence_ids",
    "confidence",
    "insufficient_evidence"
  ],
  "properties": {
    "schema_version": {"const": "grounded_answer_v1"},
    "answer": {"type": "string"},
    "claims": {
      "type": "array",
      "items": {"$ref": "#/$defs/groundedClaim"}
    },
    "evidence_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^evidence_v1_[0-9a-f]{64}$"}
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "insufficient_evidence": {"type": "boolean"}
  },
  "allOf": [
    {
      "if": {"properties": {"insufficient_evidence": {"const": true}}},
      "then": {
        "properties": {
          "answer": {"maxLength": 0},
          "claims": {"maxItems": 0},
          "evidence_ids": {"maxItems": 0}
        }
      }
    },
    {
      "if": {"properties": {"insufficient_evidence": {"const": false}}},
      "then": {
        "properties": {
          "answer": {"minLength": 1},
          "claims": {"minItems": 1},
          "evidence_ids": {"minItems": 1}
        }
      }
    }
  ],
  "$defs": {
    "groundedClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "claim_type", "text", "evidence_ids", "confidence"],
      "properties": {
        "schema_version": {"const": "grounded_claim_v1"},
        "claim_type": {"enum": ["factual", "qualification"]},
        "text": {"type": "string", "minLength": 1},
        "evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^evidence_v1_[0-9a-f]{64}$"}
        },
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"claim_type": {"const": "factual"}}},
          "then": {"properties": {"evidence_ids": {"minItems": 1}}}
        }
      ]
    }
  }
}
