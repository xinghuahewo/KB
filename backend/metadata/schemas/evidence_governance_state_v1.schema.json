{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/bgpkb/schema/evidence-governance-state-v1.json",
  "title": "EvidenceGovernanceStateV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_id",
    "object_type",
    "parse_status",
    "content_quality_status",
    "source_trust_status",
    "semantic_review_status",
    "retrieval_eligibility",
    "status_provenance",
    "migration_audit"
  ],
  "properties": {
    "schema_version": {"const": "evidence_governance_state_v1"},
    "object_id": {"type": "string", "minLength": 1},
    "object_type": {
      "enum": ["document", "block", "semantic_chunk", "retrieval_document", "source", "entity"]
    },
    "parse_status": {"enum": ["parsed", "failed", "quarantined", "unknown"]},
    "content_quality_status": {
      "enum": ["approved", "pending_review", "rejected", "quarantined", "unknown"]
    },
    "source_trust_status": {
      "enum": ["trusted", "trusted_with_caution", "untrusted", "pending", "unknown"]
    },
    "semantic_review_status": {"enum": ["approved", "pending", "rejected", "unknown"]},
    "retrieval_eligibility": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/retrievalEligibility"}
      ]
    },
    "status_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parse_status",
        "content_quality_status",
        "source_trust_status",
        "semantic_review_status"
      ],
      "properties": {
        "parse_status": {"type": "string", "minLength": 1},
        "content_quality_status": {"type": "string", "minLength": 1},
        "source_trust_status": {"type": "string", "minLength": 1},
        "semantic_review_status": {"type": "string", "minLength": 1}
      }
    },
    "migration_audit": {
      "type": "array",
      "items": {"$ref": "#/$defs/migrationAuditEvent"}
    }
  },
  "$defs": {
    "retrievalEligibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "policy_version", "rule_id", "reason", "audit"],
      "properties": {
        "status": {"enum": ["eligible", "eligible_with_caution", "ineligible"]},
        "policy_version": {"type": "string", "minLength": 1},
        "rule_id": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "audit": {
          "type": "object",
          "additionalProperties": false,
          "required": ["actor", "decision_method", "input_fingerprint", "policy_fingerprint"],
          "properties": {
            "actor": {"const": "system:retrieval_eligibility_policy"},
            "decision_method": {"const": "deterministic_policy"},
            "input_fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
            "policy_fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
          }
        }
      }
    },
    "migrationAuditEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "old_value", "new_value", "rule_id", "reason", "input_fingerprint"],
      "properties": {
        "dimension": {
          "enum": ["parse_status", "content_quality_status", "source_trust_status", "semantic_review_status"]
        },
        "old_value": {"type": ["string", "null"]},
        "new_value": {"type": "string", "minLength": 1},
        "rule_id": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "input_fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    }
  }
}
