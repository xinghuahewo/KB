{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/bgpkb/schema/corpus-ocr-assessment-v1.json",
  "title": "BGP 知识库可选 OCR 质量评估",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "assessment_id",
    "doc_id",
    "input_fingerprint",
    "status",
    "risk_level",
    "reason",
    "recommendation",
    "provider",
    "model",
    "prompt_version",
    "generated_at",
    "error_code",
    "generated_by"
  ],
  "properties": {
    "assessment_id": {"type": "string", "minLength": 1},
    "doc_id": {"type": "string", "minLength": 1},
    "input_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "status": {"type": "string", "enum": ["completed", "failed", "skipped"]},
    "risk_level": {"type": "string", "enum": ["low", "medium", "high", "unknown"]},
    "reason": {"type": "string"},
    "recommendation": {"type": "string"},
    "provider": {"type": "string", "minLength": 1},
    "model": {"type": "string", "minLength": 1},
    "prompt_version": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "minLength": 1},
    "error_code": {"type": "string"},
    "generated_by": {"const": "src/bgpkb/pipeline/assess_corpus_ocr_quality.py"}
  }
}
