{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/bgpkb/schema/canonical-asset-v2.json",
  "title": "CanonicalAssetV2",
  "type": "object",
  "additionalProperties": false,
  "required": ["asset_id", "doc_id", "asset_type", "path", "sha256", "bbox", "provenance"],
  "properties": {
    "asset_id": {"type": "string", "pattern": "^asset_v2_[0-9a-f]{64}$"},
    "doc_id": {"type": "string", "minLength": 1},
    "asset_type": {"enum": ["picture", "table_crop", "page_image"]},
    "path": {"type": "string", "minLength": 1},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "bbox": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["left", "top", "right", "bottom", "coord_origin"],
          "properties": {
            "left": {"type": "number"},
            "top": {"type": "number"},
            "right": {"type": "number"},
            "bottom": {"type": "number"},
            "coord_origin": {"enum": ["top_left", "bottom_left"]}
          }
        }
      ]
    },
    "caption": {"type": ["string", "null"]},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_snapshot_id", "source_object_digest", "source_anchor"],
      "properties": {
        "source_snapshot_id": {"type": "string", "pattern": "^snapshot_[0-9a-f]{64}$"},
        "source_object_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "source_anchor": {"type": "string", "minLength": 1}
      }
    }
  }
}
