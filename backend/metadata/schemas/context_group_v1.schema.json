{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/bgpkb/schema/context-group-v1.json",
  "title": "ContextGroupV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "context_group_id",
    "context_id",
    "mode",
    "doc_id",
    "section_path",
    "content",
    "member_evidence_ids",
    "members"
  ],
  "properties": {
    "schema_version": {"const": "context_group_v1"},
    "context_group_id": {"type": "string", "pattern": "^context_group_v1_[0-9a-f]{64}$"},
    "context_id": {"type": "string", "minLength": 1},
    "mode": {"enum": ["matched_chunk", "parent_span", "full_section", "summary"]},
    "doc_id": {"type": "string", "minLength": 1},
    "section_path": {"type": "array", "items": {"type": "string"}},
    "content": {"type": "string", "minLength": 1},
    "member_evidence_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^evidence_v1_[0-9a-f]{64}$"}
    },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "chunk_id", "source_ref", "member_index", "start_char", "end_char"],
        "properties": {
          "evidence_id": {"type": "string", "pattern": "^evidence_v1_[0-9a-f]{64}$"},
          "chunk_id": {"type": "string", "minLength": 1},
          "source_ref": {"type": "string", "minLength": 1},
          "member_index": {"type": "integer", "minimum": 0},
          "start_char": {"type": "integer", "minimum": 0},
          "end_char": {"type": "integer", "minimum": 1}
        }
      }
    }
  }
}
