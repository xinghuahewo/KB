{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bgpkb.local/schemas/cleaning_document_status_v2.schema.json",
  "title": "Docling 清洗 v2 文档状态",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "run_id", "doc_id", "source_path", "processing_fingerprint",
    "state", "transitions", "errors", "retries", "performance", "output_summary",
    "skip_reason", "updated_at"
  ],
  "properties": {
    "schema_version": {"const": "cleaning_document_status_v2"},
    "run_id": {"type": "string", "minLength": 1},
    "doc_id": {"type": "string", "minLength": 1},
    "source_path": {"type": "string", "minLength": 1},
    "processing_fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "state": {
      "enum": ["discovered", "preflighted", "parsed", "normalized", "validated", "approved", "quarantined"]
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["from", "to", "run_id", "at", "reason"],
        "properties": {
          "from": {"type": "string"}, "to": {"type": "string"},
          "run_id": {"type": "string"}, "at": {"type": "string"}, "reason": {"type": "string"}
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["stage", "error_type", "message", "retryable", "attempt", "at"],
        "properties": {
          "stage": {"type": "string"}, "error_type": {"type": "string"},
          "message": {"type": "string"}, "retryable": {"type": "boolean"},
          "attempt": {"type": "integer", "minimum": 1}, "at": {"type": "string"}
        }
      }
    },
    "retries": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["stage", "error_type", "attempt", "next_attempt", "at"],
        "properties": {
          "stage": {"type": "string"}, "error_type": {"type": "string"},
          "attempt": {"type": "integer", "minimum": 1},
          "next_attempt": {"type": "integer", "minimum": 2}, "at": {"type": "string"}
        }
      }
    },
    "performance": {
      "type": "object", "additionalProperties": false,
      "required": ["duration_seconds", "page_count", "ocr_page_count", "gpu_peak_memory_mb", "stage_durations_seconds"],
      "properties": {
        "duration_seconds": {"type": "number", "minimum": 0},
        "page_count": {"type": "integer", "minimum": 0},
        "ocr_page_count": {"type": "integer", "minimum": 0},
        "gpu_peak_memory_mb": {"type": "number", "minimum": 0},
        "stage_durations_seconds": {"type": "object", "additionalProperties": {"type": "number", "minimum": 0}}
      }
    },
    "output_summary": {
      "type": "object", "additionalProperties": false,
      "required": ["fallback_used", "counts"],
      "properties": {
        "fallback_used": {"type": "boolean"},
        "counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}}
      }
    },
    "skip_reason": {"type": ["string", "null"]},
    "updated_at": {"type": "string"}
  }
}
