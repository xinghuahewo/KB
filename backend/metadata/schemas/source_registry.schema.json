{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/bgpkb/schema/source-registry-v1.json",
  "title": "SourceRegistryV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_version", "sources"],
  "properties": {
    "schema_version": {"const": "source_registry_v1"},
    "registry_version": {"type": "string", "minLength": 1},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/source"}
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "acquisition", "source_type", "document_profile", "authority_org", "language", "license", "expected_content_types", "legacy_path", "required"],
      "properties": {
        "source_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
        "acquisition": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "origin_locator"],
          "properties": {
            "method": {"enum": ["http", "local_import"]},
            "origin_locator": {"type": "string", "minLength": 1}
          }
        },
        "source_type": {"enum": ["standard", "data_doc", "tool_doc", "paper", "case_report", "internal"]},
        "document_profile": {"enum": ["rfc", "html", "pdf_table", "openapi_yaml", "plain_text"]},
        "authority_org": {"type": "string", "minLength": 1},
        "language": {"type": "string", "minLength": 2},
        "license": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "identifier", "notes"],
          "properties": {
            "status": {"enum": ["known", "unknown", "restricted"]},
            "identifier": {"type": ["string", "null"]},
            "notes": {"type": "string"}
          }
        },
        "expected_content_types": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "legacy_path": {"type": "string", "minLength": 1},
        "required": {"type": "boolean"}
      }
    }
  }
}
