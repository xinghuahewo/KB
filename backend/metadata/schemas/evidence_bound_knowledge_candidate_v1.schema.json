{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/bgpkb/schema/evidence_bound_knowledge_candidate_v1.schema.json",
  "title": "证据绑定知识候选 v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_id",
    "candidate_type",
    "payload",
    "evidence_ids",
    "source_refs",
    "input_fingerprint",
    "confidence",
    "reason",
    "provider",
    "model_revision",
    "prompt_version",
    "governance"
  ],
  "properties": {
    "schema_version": {"const": "evidence_bound_knowledge_candidate_v1"},
    "candidate_id": {
      "type": "string",
      "pattern": "^knowledge_candidate__(entity|relation|fact)__[a-f0-9]{16}__[a-f0-9]{64}$"
    },
    "candidate_type": {"enum": ["entity", "relation", "fact"]},
    "payload": {
      "oneOf": [
        {"$ref": "#/$defs/entity_payload"},
        {"$ref": "#/$defs/relation_payload"},
        {"$ref": "#/$defs/fact_payload"}
      ]
    },
    "evidence_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "input_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "reason": {"type": "string", "minLength": 1},
    "provider": {"type": "string", "minLength": 1},
    "model_revision": {"type": "string", "minLength": 1},
    "prompt_version": {"type": "string", "minLength": 1},
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_status"],
      "properties": {"review_status": {"const": "pending_review"}}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"candidate_type": {"const": "entity"}}},
      "then": {"properties": {"payload": {"$ref": "#/$defs/entity_payload"}}}
    },
    {
      "if": {"properties": {"candidate_type": {"const": "relation"}}},
      "then": {"properties": {"payload": {"$ref": "#/$defs/relation_payload"}}}
    },
    {
      "if": {"properties": {"candidate_type": {"const": "fact"}}},
      "then": {"properties": {"payload": {"$ref": "#/$defs/fact_payload"}}}
    }
  ],
  "$defs": {
    "entity_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "entity_kind", "canonical_name"],
      "properties": {
        "type": {"const": "entity"},
        "entity_kind": {"type": "string", "minLength": 1},
        "canonical_name": {"type": "string", "minLength": 1},
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "relation_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "subject_ref", "predicate", "object_ref"],
      "properties": {
        "type": {"const": "relation"},
        "subject_ref": {"type": "string", "minLength": 1},
        "predicate": {"type": "string", "minLength": 1},
        "object_ref": {"type": "string", "minLength": 1}
      }
    },
    "fact_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "claim"],
      "properties": {
        "type": {"const": "fact"},
        "claim": {"type": "string", "minLength": 1}
      }
    }
  }
}
