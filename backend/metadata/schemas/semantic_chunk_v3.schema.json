{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/bgpkb/schema/semantic-chunk-v3.json",
  "title": "SemanticChunkV3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "chunk_id",
    "doc_id",
    "source_id",
    "source_snapshot_id",
    "source_object_digest",
    "document_profile",
    "chunker",
    "title",
    "section_path",
    "semantic_unit",
    "content",
    "content_hash",
    "exact_content_hash",
    "source_block_ids",
    "source_block_hashes",
    "source_refs",
    "page_numbers",
    "language",
    "estimated_tokens",
    "short_content_rule_id"
  ],
  "properties": {
    "schema_version": {"const": "semantic_chunk_v3"},
    "chunk_id": {"type": "string", "pattern": "^semantic_chunk_v3_[0-9a-f]{64}$"},
    "doc_id": {"type": "string", "minLength": 1},
    "source_id": {"type": "string", "minLength": 1},
    "source_snapshot_id": {"type": "string", "pattern": "^snapshot_[0-9a-f]{64}$"},
    "source_object_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "document_profile": {"enum": ["rfc", "document", "plain_text", "html", "pdf", "paper", "pdf_table", "openapi", "yaml", "openapi_yaml"]},
    "chunker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "config_version", "config_fingerprint"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "config_version": {"type": "string", "minLength": 1},
        "config_fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "title": {"type": "string", "minLength": 1},
    "section_path": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "semantic_unit": {
      "enum": ["paragraph", "list", "table", "code", "formula", "operation", "schema", "security", "error", "term"]
    },
    "content": {"type": "string", "minLength": 1},
    "content_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "exact_content_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "source_block_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^block_v2_[0-9a-f]{64}$"}
    },
    "source_block_hashes": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "page_numbers": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "integer", "minimum": 1}
    },
    "language": {"type": "string", "minLength": 1},
    "estimated_tokens": {"type": "integer", "minimum": 1},
    "short_content_rule_id": {"type": ["string", "null"]}
  }
}
