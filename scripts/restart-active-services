#!/usr/bin/env bash
set -euo pipefail

DEPLOY_ROOT="${1:-${BGPKB_DEPLOY_ROOT:-/home/wbt/DB}}"
CODE_ROOT="$DEPLOY_ROOT/current"
DATA_ROOT="$DEPLOY_ROOT/current-artifact/data"
BGPKB_ENV_FILE="${BGPKB_ENV_FILE:-/etc/bgpkb/runtime.env}"

if [[ ! -r "$BGPKB_ENV_FILE" ]]; then
  printf '外部运行环境文件不存在或不可读：%s\n' "$BGPKB_ENV_FILE" >&2
  exit 2
fi
set -a
source "$BGPKB_ENV_FILE"
set +a
if [[ -z "${DEEPSEEK_API_KEY:-}" ]]; then
  printf '外部运行环境文件缺少 DEEPSEEK_API_KEY。\n' >&2
  exit 2
fi

if [[ -f "$CODE_ROOT/backend/src/bgpkb/api/app.py" ]]; then
  API_APP="bgpkb.api.app:app"
else
  API_APP="bgpkb.service.app:app"
fi

screen -S bgpkb_frontend_wbt -X quit 2>/dev/null || true
screen -S bgpkb_fastapi_wbt -X quit 2>/dev/null || true

screen -dmS bgpkb_fastapi_wbt bash -lc \
  "cd '$CODE_ROOT/backend' && BGPKB_DATA_DIR='$DATA_ROOT' BGP_RAG_REQUIRE_RERANKER=1 uv run uvicorn '$API_APP' --host 0.0.0.0 --port 39281"
screen -dmS bgpkb_frontend_wbt bash -lc \
  "cd '$CODE_ROOT/frontend' && python3 scripts/serve_static_with_proxy.py --host 0.0.0.0 --port 39280 --directory out --backend http://127.0.0.1:39281"
